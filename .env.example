# ===== LLM =====
# Get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== Firecrawl (premium backend — optional) =====
# Get from https://firecrawl.dev
# Leave blank to use only the free local Playwright + Crawl4AI backend
FIRECRAWL_API_KEY=fc-your-firecrawl-key
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# When true and key is set, /crawl uses Firecrawl by default (auto mode)
FIRECRAWL_DEFAULT_BACKEND=true

# ===== Database (Neon) =====
# Get from https://console.neon.tech → Connection Details
# Format: postgresql+asyncpg://user:pass@ep-xxx.region.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/crawlforge?ssl=require

# ===== App =====
APP_ENV=production
SECRET_KEY=change-me-to-random-string
LOG_LEVEL=INFO

# ===== Browser =====
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_HEADLESS=true
MAX_CONCURRENT_BROWSERS=2

# Stealth mode — applies anti-detection patches (webdriver property, UA spoofing,
# plugin/language spoofing). Requires `pip install playwright-stealth` to use the
# strong patches, otherwise falls back to manual JS injection.
STEALTH_MODE=false
# Proxy rotation — comma-separated list, e.g. "http://user:pass@host:8000,http://host2:8000"
PROXY_LIST=
PROXY_ROTATION=false

# ===== Crawl4AI =====
CRAWL4AI_MAX_CONCURRENCY=3
CRAWL4AI_TIMEOUT_SECONDS=60

# ===== Agent limits =====
AGENT_MAX_STEPS=20
AGENT_TIMEOUT_SECONDS=300